{% import 'macros.html.j2' as m %}
<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8">
    <title>Experience | {{ personal.name }}</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/terminal.css@0.7.4/dist/terminal.min.css" />
    <style>
        @media print {
            .web-only { display: none; }
            .card { break-inside: avoid; margin-bottom: 20px; }
            .terminal-nav { display: none; }
        }
        @media screen {
            .print-only { display: none; }
        }
        .company-header {
            display: flex;
            align-items: center;
            gap: 15px;
            margin-bottom: 10px;
        }
        .company-logo {
            display: block;
            width: 50px;
            height: 50px;
            object-fit: contain;
            border-radius: 4px;
        }
    </style>
</head>
<body class="terminal">
    <div class="container">
        <nav class="terminal-nav">
            <a href="index.html" class="btn btn-default">← Home</a>
        </nav>
        
        <main>
            <h2>Professional Experience</h2>
            {% for job in main %}
            <div class="card">
                <div class="company-header">
                    <img src="assets/{{ job.image.split('/')[-1] }}" 
                         alt="{{ job.company }}" 
                         class="company-logo">
                    <h3>{{ m.link(job.url, job.company) }}</h3>
                </div>
                <p><strong>{{ job.role }}</strong> | {{ job.dates }}</p>
                <ul>
                    {% for bullet in job.bullets %}
                    <li>{{ bullet }}</li>
                    {% endfor %}
                </ul>
            </div>
            {% endfor %}
        </main>

        <footer style="margin-top: 40px; padding-top: 20px; border-top: 1px solid #e1e1e1;">
            <p>Looking for the complete background?</p>
            <a href="addendum.html" class="btn btn-ghost">View Service History</a>
            <a href="JNMansfield-Service-History.pdf" class="btn btn-ghost">Download Service History PDF</a>
        </footer>
    </div>
</body>
</html>
