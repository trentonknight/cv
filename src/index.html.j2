{% set page = "index" %}
<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8">
    <title>{{ personal.name }} | AI Cloud Architect</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/terminal.css@0.7.4/dist/terminal.min.css" />
    <link rel="stylesheet" href="style.css" />
</head>
<body class="terminal">
    <div class="container page-wrapper">
        {% include 'sidebar.html.j2' %}
        <main>
            <section class="hero-container">
                <div class="hero-content">
                    <h1>{{ personal.name }}</h1>
                    <p><strong>Senior AI Cloud Engineer & Architect</strong></p>
                    <p>Bridging the gap between legacy infrastructure, cloud-native DevOps, and the next generation of Edge AI / SLM solutions.</p>
                </div>
            </section>

            <h2>Core Competencies</h2>
            <div class="skills-grid">
                <div class="skill-card">Platform Engineering</div>
                <div class="skill-card">AI/ML Infrastructure</div>
                <div class="skill-card">GitOps (Argo/Flux)</div>
                <div class="skill-card">SLM & Edge AI</div>
                <div class="skill-card">Cloud Architecture</div>
                <div class="skill-card">Infrastructure as Code</div>
            </div>

            <h2>Current Research Focus</h2>
            <ul>
                {% for r in research.research %}
                <li><strong>{{ r.topic }}</strong>: {{ r.desc }}</li>
                {% endfor %}
            </ul>
        </main>
    </div>
</body>
</html>
