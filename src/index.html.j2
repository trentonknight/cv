<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8">
    <title>{{ personal.name }} | Architect</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/terminal.css@0.7.4/dist/terminal.min.css" />
    <style>
        /* Ensures cards behave well in both browser and PDF */
        @media print {
            .terminal-nav { display: none; }
            .card { break-inside: avoid; }
        }
    </style>
</head>
<body class="terminal">
    <div class="container">
        <header>
            <div class="terminal-nav">
                <div class="terminal-logo"><span class="logo terminal-prompt">{{ personal.name }}</span></div>
            </div>
            <p>{{ personal.title }} | {{ personal.location }}</p>
            <div class="terminal-nav">
                <a href="experience.html" class="btn btn-primary">Professional Experience</a>
                <a href="addendum.html" class="btn btn-default">Service History</a>
                <!-- Link to the PDF generated by WeasyPrint -->
                <a href="JNMansfield-Professional-CV.pdf" class="btn btn-ghost">Download PDF</a>
            </div>
        </header>
        
        <main>
            <h2>Core Competencies</h2>
            <p>Platform Engineering, AI Infrastructure, GitOps, and Small Language Models (SLM).</p>
            
            <h2>Current Research Focus</h2>
            <ul>
                {% for r in research %}
                <li><strong>{{ r.topic }}</strong>: {{ r.desc }}</li>
                {% endfor %}
            </ul>
        </main>
    </div>
</body>
</html>
