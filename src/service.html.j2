{% import 'macros.html.j2' as m %}
{% set page = "svc" %}
<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8">
    <title>Service History | {{ personal.name }}</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/terminal.css@0.7.4/dist/terminal.min.css" />
    <link rel="stylesheet" href="style.css" />
</head>
<body class="terminal">
    <div class="page-wrapper">
        {% include 'sidebar.html.j2' %}
        <main>
            <h2>Service History</h2>
            {% for job in service.main %}
            <div class="card">
                <div class="company-header">
                    <img src="assets/{{ job.image.split('/')[-1] }}" alt="{{ job.company }}" class="company-logo">
                    <h3>{{ m.link(job.url, job.company) }}</h3>
                </div>
                <p><strong>{{ job.role }}</strong> | {{ job.dates }} | {{ job.location }}</p>
                <ul>
                    {% for bullet in job.bullets %}
                    <li>{{ bullet }}</li>
                    {% endfor %}
                </ul>
            </div>
            {% endfor %}
        </main>
    </div>
</body>
</html>
