<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8">
    <title>Service History | {{ personal.name }}</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/terminal.css@0.7.4/dist/terminal.min.css" />
</head>
<body class="terminal">
    <div class="container">
        <nav class="terminal-nav">
            <a href="index.html" class="btn btn-default">← Back to Main CV</a>
        </nav>
        <main>
            <h2>Full Armed Forces History</h2>
            {% for job in addendum %}
            <div class="card">
                <h3>{{ job.company }}</h3>
                <p><strong>{{ job.role }}</strong> | {{ job.dates }}</p>
                <ul>
                    {% for bullet in job.bullets %}<li>{{ bullet }}</li>{% endfor %}
                </ul>
            </div>
            {% endfor %}
        </main>
    </div>
</body>
</html>
