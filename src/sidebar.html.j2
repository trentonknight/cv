<aside class="terminal sidebar web-only">
    <a href="index.html" class="sidebar-logo">
        {{ personal.name }}
    </a>
    
    <nav class="sidebar-nav">
        {% set nav_items = [
            ('index', 'Home', 'index.html'), 
            ('exp', 'Experience', 'experience.html'), 
            ('svc', 'Service History', 'service.html'), 
            ('con', 'Contacts', 'contacts.html')
        ] %}
        {% for id, label, url in nav_items %}
            <a href="{{ url }}" class="btn {{ 'btn-primary' if page == id else 'btn-default' }} btn-block">
                {{ label }}
            </a>
        {% endfor %}
    </nav>

    <div class="sidebar-divider"></div>

    <nav class="sidebar-pdfs">
        <a href="{{ personal.pdf_main }}" class="btn btn-ghost btn-block"> ⤓ Professional CV (PDF) </a>
        <a href="{{ personal.pdf_addendum }}" class="btn btn-ghost btn-block"> ⤓ Service History (PDF) </a>
    </nav>

    <div class="sidebar-divider"></div>

    <div class="sidebar-contact">
        <div>{{ personal.location }}</div>
        <a href="mailto:{{ personal.email }}" class="text-accent">{{ personal.email }}</a><br>
        <span class="phone-display">{{ personal.phone }}</span>
        
        <div class="sidebar-links">
            <a href="https://{{ personal.linkedin }}" target="_blank">LinkedIn</a>
            <a href="https://{{ personal.github }}" target="_blank">GitHub</a>
            <a href="https://{{ personal.gitlab }}" target="_blank">GitLab</a>
        </div>
    </div>
</aside>
