{% import 'macros.html.j2' as m %}
{# Set the page variable for the sidebar logic #}
{% set page = "index" %}
<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8">
    <title>{{ personal.name }} | Architect</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/terminal.css@0.7.4/dist/terminal.min.css" />
    <link rel="stylesheet" href="style.css" />
</head>
<body class="terminal">
    <div class="container page-wrapper">
        
        {% include 'sidebar.html.j2' %}

        <main>
            <h2>Core Competencies</h2>
            <p>Platform Engineering, AI Infrastructure, GitOps, and Small Language Models (SLM).</p>

            <h2>Current Research Focus</h2>
            <ul>
                {% for r in research %}
                <li><strong>{{ r.topic }}</strong>: {{ r.desc }}</li>
                {% endfor %}
            </ul>
        </main>
    </div>
</body>
</html>
